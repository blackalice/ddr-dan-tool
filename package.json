{
  "name": "ddr-toolkit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
"scripts": {
  "dev": "concurrently \"npm:dev:vite\" \"npm:dev:wrangler\"",

  "dev:vite": "vite",
  "dev:wrangler": "wrangler dev",

  "prepare:data": "node scripts/generate-sm-list.mjs && node scripts/generate-processed-data.mjs && node scripts/extract-stepmania-tech-counts.mjs && node scripts/generate-song-meta.mjs && node scripts/generate-world-new-challenges.mjs && node scripts/generate-ddr-a3-override.mjs && npm run build:audio && node scripts/generate-song-lengths.mjs && npm run sync:public",
  "prepare:data:force": "node scripts/generate-sm-list.mjs --force && node scripts/generate-processed-data.mjs --force && node scripts/extract-stepmania-tech-counts.mjs --force && node scripts/generate-song-meta.mjs --force && node scripts/generate-world-new-challenges.mjs --force && node scripts/generate-ddr-a3-override.mjs --force && npm run build:audio:force && node scripts/generate-song-lengths.mjs --force && npm run sync:public:force",

  "dev:full": "npm run prepare:data && npm run dev",

  "build": "vite build",
  "prebuild": "npm run prepare:data",

  "postinstall": "npm run prepare:data",

  "lint": "eslint .",
  "preview": "vite preview",

  "cf:dev": "wrangler dev",

  "deploy": "npm run build && npm run deploy:worker && npm run deploy:pages",
  "deploy:worker": "wrangler deploy --env production",
  "deploy:pages": "wrangler pages deploy dist",

  "parse:scores": "node scripts/parse-ganymede-html.mjs",
  "extract:stepmania-tech": "node scripts/extract-stepmania-tech-counts.mjs",
  "extract:stepmania-tech:force": "node scripts/extract-stepmania-tech-counts.mjs --force",
  "build:audio": "node scripts/build-audio-lengths.mjs",
  "build:audio:force": "node scripts/build-audio-lengths.mjs --force",
  "sync:public": "node scripts/sync-public-assets.mjs",
  "sync:public:force": "node scripts/sync-public-assets.mjs --force"
},

  "dependencies": {
    "@dnd-kit/core": " ^6.1.0 ",
    "@dnd-kit/sortable": " ^8.0.0 ",
    "@dnd-kit/utilities": " ^3.2.2 ",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@google/generative-ai": "^0.24.1",
    "argon2-browser": "^1.18.0",
    "chart.js": "^4.5.0",
    "cheerio": "^1.1.2",
    "clsx": "^2.1.1",
    "fraction.js": "^4.0.13",
    "hono": "^4.11.7",
    "jose": "^6.0.12",
    "react": "^19.1.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.12.0",
    "react-select": "^5.10.1",
    "react-window": "^1.8.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.3",
    "concurrently": "^9.2.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "music-metadata": "^11.8.3",
    "vite": "^7.1.6",
    "vite-plugin-pwa": "^1.2.0",
    "wrangler": "^4.36.0"
  },
  "overrides": {
    "undici": "^7.18.2"
  },
  "description": "![screenshot](screenshot.png)",
  "main": "eslint.config.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
